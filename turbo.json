{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },

    "test": {
      "cache": false
    },

    "start": {
      "cache": false
    },

    "lint": {
      "cache": false
    }
  }
}